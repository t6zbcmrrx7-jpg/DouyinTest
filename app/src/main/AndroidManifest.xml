<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:label="QQLogin测试工具"
        android:supportsRtl="true"
        android:theme="@style/Theme.DouyinTest"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DouyinTest">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- tencent:// URL Scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tencent1105602870" />
            </intent-filter>

        </activity>

        <!-- AgentActivity: QQ OAuth WebView 授权 -->
        <activity
            android:name=".AgentActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.DouyinTest">

            <!-- auth://tauth.qq.com QQ OAuth 回调 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="auth" android:host="tauth.qq.com" />
            </intent-filter>

            <!-- tencent:// Scheme (从外部跳转过来) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tencent1105602870" />
            </intent-filter>

            <!-- 腾讯开放 SDK 授权 Action -->
            <intent-filter>
                <action android:name="com.tencent.open.agent.Request" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

    </application>
</manifest>
